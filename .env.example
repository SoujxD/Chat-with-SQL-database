# Copy to .env and fill in. The backend reads these at startup.
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides
GROQ_MODEL=Llama3-8b-8192
HISTORY_MAX_ITEMS=100
MAX_RESULT_ROWS=200
QUERY_TIMEOUT_SECONDS=5

# Postgres (sample ecommerce database). These are also read by docker-compose
# to configure the postgres container itself.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chatsql
POSTGRES_PASSWORD=chatsql
POSTGRES_DB=ecommerce
